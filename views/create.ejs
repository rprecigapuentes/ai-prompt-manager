<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Prompt — AI Prompt Manager</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="nav-brand">AI Prompt Manager</a>
    <a href="/logout" class="btn btn-secondary btn-sm">Logout</a>
  </nav>

  <main class="container">
    <div class="page-header">
      <h2>New Prompt</h2>
      <a href="/" class="btn btn-ghost">← Back</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/prompts" method="POST" class="prompt-form">
      <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" placeholder="Give your prompt a name" required>
      </div>
      <div class="form-group">
        <label for="body">Prompt Body</label>
        <textarea id="body" name="body" rows="8" placeholder="Write your prompt here..." required></textarea>
      </div>
      <div class="form-group">
        <label for="tags">Tags <span class="label-hint">(comma-separated)</span></label>
        <input type="text" id="tags" name="tags" placeholder="e.g. coding, writing, summarize">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Prompt</button>
        <a href="/" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </main>
</body>
</html>
